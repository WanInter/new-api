# Generate a unique value for each setting with: openssl rand -hex 32
# POSTGRES_PASSWORD and REDIS_PASSWORD are interpolated into connection URIs,
# so restrict them to RFC 3986 unreserved characters: A-Z a-z 0-9 - . _ ~
# Do not commit the real .env file.
POSTGRES_PASSWORD=replace-with-a-random-password
REDIS_PASSWORD=replace-with-a-random-password
SESSION_SECRET=replace-with-a-random-session-secret
