new-api.waypeak.work {
	encode zstd gzip

	@scanner path /.env* /.git/* /.vscode/* /.DS_Store /wp-admin* /wp-login.php /xmlrpc.php /server-status /info.php /actuator/* /debug/* /telescope/* /v2/_catalog
	respond @scanner 404

	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}

	reverse_proxy new-api:3000
}
